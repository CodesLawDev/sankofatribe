# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Paystack Configuration (Primary Payment Method)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# BMS SMS Configuration (existing provider)
BMS_API_KEY=your_bms_api_key_here
BMS_SENDER_ID=Sankofa

# Cron Job Security
CRON_SECRET=your_random_secret_here_min_32_chars

# Base URL (for production)
NEXT_PUBLIC_BASE_URL=https://your-domain.com
