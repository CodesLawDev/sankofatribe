# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Paystack Configuration (event ticket payments / legacy flows)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# Hubtel Configuration (shop checkout)
HUBTEL_API_KEY=your_hubtel_api_key_here
HUBTEL_ACCOUNT_ID=your_hubtel_account_id_here
HUBTEL_MERCHANT_ACCOUNT_NUMBER=your_hubtel_merchant_account_number_here
HUBTEL_WEBHOOK_SECRET=your_hubtel_webhook_secret_here

# Brevo Configuration (newsletter and marketing emails)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_ID=your_brevo_list_id_here

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=233XXXXXXXXXX

# FlashSMS Configuration
FLASHSMS_API_KEY=your_flashsms_api_key_here
FLASHSMS_SENDER_ID=Sankofa

# Cron Job Security
CRON_SECRET=your_random_secret_here_min_32_chars

# Base URL (for production)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Sanity Webhook Secret (for Sanity → Postgres sync)
SANITY_WEBHOOK_SECRET=generate_with_node_-e_"console.log(require('crypto').randomBytes(32).toString('hex'))"
