// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// Unified Users table for both admin staff and customers
model User {
  id                    String      @id @default(cuid())
  email                 String      @unique @db.VarChar(255)
  phone                 String?     @unique @db.VarChar(20)
  firstName             String      @db.VarChar(100)
  lastName              String      @db.VarChar(100)
  passwordHash          String
  role                  UserRole    @default(CUSTOMER)
  status                UserStatus  @default(ACTIVE)
  
  // Permissions (for admin staff)
  permissions           String[]    @default([])
  
  // Profile
  profileImage          String?
  bio                   String?     @db.Text
  
  // Communication preferences
  preferences           Json @default("{\"emailMarketing\": true, \"smsMarketing\": false, \"orderUpdates\": true}")
  
  // Customer data
  loyaltyPoints         Int         @default(0)
  totalOrders           Int         @default(0)
  totalSpent            Decimal     @default(0) @db.Decimal(10, 2)
  
  // Metadata
  registeredAt          DateTime    @default(now())
  lastLogin             DateTime?
  updatedAt             DateTime    @updatedAt

  // Password reset
  resetToken            String?
  resetTokenExpiry      DateTime?
  
  // Relations
  addresses             Address[]     @relation("UserAddresses")
  orders                Order[]       @relation("UserOrders")
  wishlistItems         WishlistItem[] @relation("UserWishlist")
  loginHistory          LoginHistory[] @relation("UserLoginHistory")
  reviews               CustomerReview[] @relation("UserReviews")
  
  @@index([email])
  @@index([role])
  @@index([status])
  @@index([registeredAt])
}

model Address {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation("UserAddresses", fields: [userId], references: [id], onDelete: Cascade)
  ordersShipped         Order[]     @relation("OrderShippingAddress")
  
  label                 String?     @default("Address")
  street                String      @db.VarChar(255)
  city                  String      @db.VarChar(100)
  region                String?     @db.VarChar(100)
  postalCode            String?     @db.VarChar(20)
  country               String      @db.VarChar(100)
  isDefault             Boolean     @default(false)
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  @@index([userId])
}

model Order {
  id                    String      @id @default(cuid())
  orderNumber           String      @unique
  sanityId              String?     @unique  // Sanity document _id (for store orders synced from Sanity)
  userId                String?
  user                  User?       @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)
  
  // Order details
  subtotal              Decimal     @db.Decimal(10, 2)
  discount              Decimal     @default(0) @db.Decimal(10, 2)
  shipping              Decimal     @default(0) @db.Decimal(10, 2)
  tax                   Decimal     @default(0) @db.Decimal(10, 2)
  total                 Decimal     @db.Decimal(10, 2)
  
  // Promo code used
  promoCode             String?
  
  // Status
  status                OrderStatus @default(PENDING)
  paymentStatus         String      @default("pending")
  
  // Payment info
  paymentReference      String?
  paymentProvider       String?     // "paystack" | "hubtel"
  paymentMethod         String?     // "card", "mobile_money", etc.
  paidAt                DateTime?
  
  // Guest customer info (when no userId)
  customerEmail         String?     @db.VarChar(255)
  customerPhone         String?     @db.VarChar(20)
  customerFirstName     String?     @db.VarChar(100)
  customerLastName      String?     @db.VarChar(100)
  
  // Shipping
  shippingAddressId     String?
  shippingAddress       Address?    @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  shippingCity          String?     @db.VarChar(100)
  shippingLandmark      String?     @db.VarChar(255)
  
  // Items
  items                 OrderItem[]
  payments              Payment[]
  
  // Automations
  followUpEmailSent     Boolean     @default(false)
  
  // Metadata
  notes                 String?     @db.Text
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  @@index([userId])
  @@index([sanityId])
  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
}

model OrderItem {
  id                    String      @id @default(cuid())
  orderId               String
  order                 Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId             String      // Reference to Sanity product
  productName           String
  price                 Decimal     @db.Decimal(10, 2)
  quantity              Int
  size                  String?
  color                 String?
  
  @@index([orderId])
}

model WishlistItem {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation("UserWishlist", fields: [userId], references: [id], onDelete: Cascade)
  productId             String      // Reference to Sanity product
  
  addedAt               DateTime    @default(now())
  
  @@unique([userId, productId])
  @@index([userId])
}

model LoginHistory {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation("UserLoginHistory", fields: [userId], references: [id], onDelete: Cascade)
  
  ipAddress             String?
  userAgent             String?     @db.Text
  loginTime             DateTime    @default(now())
  logoutTime            DateTime?
  
  @@index([userId])
  @@index([loginTime])
}

// Analytics tracking for site visits
model PageView {
  id                    String      @id @default(cuid())
  path                  String      @db.VarChar(500)
  userId                String?     // Optional - tracks authenticated users
  sessionId             String      // Unique session identifier
  ipAddress             String?     @db.VarChar(50)
  userAgent             String?     @db.Text
  referrer              String?     @db.VarChar(500)
  country               String?     @db.VarChar(100)
  device                String?     @db.VarChar(50) // mobile, tablet, desktop
  
  createdAt             DateTime    @default(now())
  
  @@index([createdAt])
  @@index([userId])
  @@index([sessionId])
  @@index([path])
}

// Monthly analytics reports
model MonthlyReport {
  id                    String      @id @default(cuid())
  month                 Int         // 1-12
  year                  Int
  
  totalOrders           Int         @default(0)
  totalRevenue          Decimal     @default(0) @db.Decimal(10, 2)
  totalPageViews        Int         @default(0)
  uniqueVisitors        Int         @default(0)
  newCustomers          Int         @default(0)
  
  // Payment stats
  successfulPayments    Int         @default(0)
  failedPayments        Int         @default(0)
  paymentRevenue        Decimal     @default(0) @db.Decimal(10, 2)
  
  // SMS sent status
  smsSent               Boolean     @default(false)
  smsRecipients         String[]    @default([])
  smsSentAt             DateTime?
  
  createdAt             DateTime    @default(now())
  
  @@unique([month, year])
  @@index([createdAt])
}

// Event Ticket System
enum TicketStatus {
  AVAILABLE
  USED
  CANCELLED
}

model EventTicketTier {
  id                    String      @id @default(cuid())
  eventId               String      // Reference to Sanity event
  name                  String      @db.VarChar(100) // e.g., "VIP", "Standard", "Early Bird"
  description           String?     @db.Text
  price                 Decimal     @db.Decimal(10, 2) // 0 for free events
  quantity              Int         // Total tickets available for this tier
  sold                  Int         @default(0) // Tickets already sold
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  // Relations
  ticketOrders          EventTicketOrder[] @relation("TierOrders")
  
  @@index([eventId])
}

model EventTicketOrder {
  id                    String      @id @default(cuid())
  orderId               String      @unique // Unique reference for this order
  eventId               String      // Reference to Sanity event
  tierId                String
  tier                  EventTicketTier @relation("TierOrders", fields: [tierId], references: [id], onDelete: Cascade)
  
  // Buyer information
  buyerEmail            String      @db.VarChar(255)
  buyerPhone            String?     @db.VarChar(20)
  buyerName             String      @db.VarChar(255)
  
  // Order details
  ticketCount           Int         // Number of tickets in this order
  totalAmount           Decimal     @db.Decimal(10, 2) // Total price
  currency              String      @default("GHS") @db.VarChar(3)
  
  // Attendee data (stored at purchase time for both providers)
  attendees             Json?       // JSON array of { name, email, phone }
  
  // Payment info
  paymentStatus         String      @default("pending") // pending, completed, failed
  paymentReference      String?     // Paystack reference
  paymentMethod         String?     @default("paystack")
  
  // Ticket info
  status                String      @default("pending") // pending, completed, cancelled
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  // Relations
  tickets               EventTicket[] @relation("OrderTickets")
  
  @@index([eventId])
  @@index([paymentStatus])
  @@index([status])
  @@index([createdAt])
}

model EventTicket {
  id                    String      @id @default(cuid())
  ticketId              String      @unique // Unique ticket identifier (e.g., "EVT-001-TK-12345")
  orderId               String
  order                 EventTicketOrder @relation("OrderTickets", fields: [orderId], references: [id], onDelete: Cascade)
  
  eventId               String      // Reference to Sanity event
  tierId                String      // Reference to ticket tier
  
  // Attendee information (person using the ticket)
  attendeeEmail         String      @db.VarChar(255)
  attendeePhone         String?     @db.VarChar(20)
  attendeeName          String      @db.VarChar(255)
  
  // Ticket details
  status                TicketStatus @default(AVAILABLE) // AVAILABLE, USED, CANCELLED
  usedAt                DateTime?   // When the ticket was scanned/validated
  
  // QR Code for scanning at entry
  qrCode                String?     @db.Text // QR code data URL containing ticket verification data
  
  // Download/wallet
  walletPassUrl         String?     // URL to Apple Wallet pass (.pkpass)
  imageUrl              String?     // URL to downloadable ticket image
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  @@index([eventId])
  @@index([orderId])
  @@index([status])
  @@index([attendeeEmail])
}

// Mirror of Sanity events for DB queries and joins
model EventRecord {
  id          String   @id @default(cuid())
  sanityId    String   @unique
  slug        String?  @unique
  title       String

  eventDate   DateTime
  endDate     DateTime?

  // Location fields
  venue       String?
  address     String?
  city        String?
  isVirtual   Boolean  @default(false)
  virtualLink String?

  status      String   @default("upcoming")
  featured    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sanityId])
  @@index([eventDate])
}

// Newsletter subscribers
model NewsletterSubscriber {
  id            String    @id @default(cuid())
  email         String    @unique @db.VarChar(255)
  firstName     String?   @db.VarChar(100)
  lastName      String?   @db.VarChar(100)
  phone         String?   @db.VarChar(20)
  status        String    @default("active") @db.VarChar(20) // active, unsubscribed
  source        String?   @db.VarChar(50) // footer, popup, checkout, etc.

  // Mailchimp integration
  mailchimpId   String?

  // Preferences (JSON)
  preferences   Json      @default("{}")

  // Tracking
  ipAddress     String?   @db.VarChar(50)
  userAgent     String?   @db.Text

  subscribedAt  DateTime  @default(now())
  confirmedAt   DateTime?
  unsubscribedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([status])
}

// Payment records synced from Sanity
model Payment {
  id                String    @id @default(cuid())
  sanityId          String?   @unique  // Sanity document _id
  reference         String    @unique  // Paystack/Hubtel reference
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  amount            Decimal   @db.Decimal(10, 2)
  currency          String    @default("GHS") @db.VarChar(3)
  status            String    @default("pending") // success, failed, pending
  provider          String?   // "paystack" | "hubtel"
  paymentMethod     String?   // "card", "mobile_money", etc.

  customerEmail     String?   @db.VarChar(255)
  customerPhone     String?   @db.VarChar(20)

  paidAt            DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([orderId])
  @@index([reference])
  @@index([status])
  @@index([createdAt])
}

// Mirror of Sanity products for DB queries and joins
model ProductRecord {
  id            String    @id @default(cuid())
  sanityId      String    @unique
  slug          String?   @unique
  name          String
  price         Decimal   @db.Decimal(10, 2)

  // Discount info
  hasDiscount   Boolean   @default(false)
  discountType  String?   // "percentage" | "fixed"
  discountValue Decimal?  @db.Decimal(10, 2)

  // Status
  inStock       Boolean   @default(true)
  featured      Boolean   @default(false)
  soldCount     Int       @default(0)
  audience      String?   // "men", "women", "kids", "unisex"

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sanityId])
  @@index([slug])
  @@index([featured])
}

// Abandoned Cart tracking for automated emails
model AbandonedCart {
  id            String    @id @default(cuid())
  email         String    @db.VarChar(255)
  cartData      Json      // Store the cart items
  totalValue    Decimal   @default(0) @db.Decimal(10, 2)
  
  // Status
  recovered     Boolean   @default(false) // True if they came back and bought it
  emailSent     Boolean   @default(false) // True if the cron job already sent the email
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([emailSent])
  @@index([updatedAt])
}

// ─── Customer Review Platform ───────────────────────────────────────────────

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model CustomerReview {
  id               String        @id @default(cuid())

  // Product reference (Sanity)
  productId        String        // Sanity product _id
  productName      String        @db.VarChar(200)
  productSlug      String?       @db.VarChar(200)

  // Reviewer
  userId           String?       // Optional — linked User
  authorName       String        @db.VarChar(100)
  authorEmail      String?       @db.VarChar(255)
  instagramHandle  String?       @db.VarChar(50)

  // Review content
  rating           Int           // 1–5
  title            String        @db.VarChar(150)
  comment          String        @db.Text

  // Fit & sizing
  sizePurchased    String?       @db.VarChar(20)
  fitExperience    String?       @db.VarChar(30) // "true-to-size" | "runs-small" | "runs-large"
  recommend        Boolean       @default(true) // Whether user recommends product

  // Moderation
  status           ReviewStatus  @default(PENDING)
  isFeatured       Boolean       @default(false)
  isVerified       Boolean       @default(false) // verified buyer badge

  // Engagement
  helpfulCount     Int           @default(0)

  // Admin reply
  adminReply       String?       @db.Text
  adminRepliedAt   DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  user             User?         @relation("UserReviews", fields: [userId], references: [id], onDelete: SetNull)
  photos           ReviewPhoto[]
  helpful          ReviewHelpful[]

  @@index([productId])
  @@index([productSlug])
  @@index([status])
  @@index([rating])
  @@index([isFeatured])
  @@index([isVerified])
  @@index([createdAt])
}

model ReviewPhoto {
  id         String         @id @default(cuid())
  reviewId   String
  review     CustomerReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url        String         // Cloudinary secure URL
  publicId   String         // Cloudinary public_id (for deletion)
  width      Int?           // Image dimensions for layout
  height     Int?
  createdAt  DateTime       @default(now())

  @@index([reviewId])
}

model ReviewHelpful {
  id        String         @id @default(cuid())
  reviewId  String
  review    CustomerReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  sessionId String         // Track by session to prevent duplicate votes
  createdAt DateTime       @default(now())

  @@unique([reviewId, sessionId])
  @@index([reviewId])
}
